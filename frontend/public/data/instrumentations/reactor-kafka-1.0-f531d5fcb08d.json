{
  "id": "reactor-kafka-1.0",
  "display_name": "Reactor Kafka",
  "library_group": "reactor",
  "description": "This instrumentation enables messaging spans for Reactor Kafka message consumers.\n",
  "library_link": "https://projectreactor.io/docs/kafka/release/reference/",
  "source_path": "instrumentation/reactor/reactor-kafka-1.0",
  "semantic_conventions": [
    "MESSAGING_SPANS"
  ],
  "scope": {
    "name": "io.opentelemetry.reactor-kafka-1.0"
  },
  "javaagent_target_versions": [
    "io.projectreactor.kafka:reactor-kafka:[1.0.0,)"
  ],
  "configurations": [
    {
      "name": "otel.instrumentation.messaging.experimental.receive-telemetry.enabled",
      "description": "Enables experimental receive telemetry, which will cause consumers to start a new trace, with only a span link connecting it to the producer trace.\n",
      "type": "boolean",
      "default": false
    },
    {
      "name": "otel.instrumentation.messaging.experimental.capture-headers",
      "description": "Enables capturing messaging headers as span attributes. Provide a comma-separated list of header names to capture.\n",
      "type": "list",
      "default": ""
    },
    {
      "name": "otel.instrumentation.kafka.experimental-span-attributes",
      "description": "Enables the capture of the experimental consumer attribute `kafka.record.queue_time_ms`.",
      "type": "boolean",
      "default": false
    }
  ],
  "telemetry": {
    "default": {
      "metrics": [],
      "spans": [
        {
          "span_kind": "CONSUMER",
          "attributes": [
            {
              "name": "kafka.record.queue_time_ms",
              "type": "LONG",
              "semconv": false
            },
            {
              "name": "messaging.client_id",
              "type": "STRING",
              "semconv": false
            },
            {
              "name": "messaging.destination.name",
              "type": "STRING",
              "semconv": true
            },
            {
              "name": "messaging.destination.partition.id",
              "type": "STRING",
              "semconv": true
            },
            {
              "name": "messaging.kafka.message.key",
              "type": "STRING",
              "semconv": true
            },
            {
              "name": "messaging.kafka.message.offset",
              "type": "LONG",
              "semconv": false
            },
            {
              "name": "messaging.message.body.size",
              "type": "LONG",
              "semconv": true
            },
            {
              "name": "messaging.operation",
              "type": "STRING",
              "semconv": false
            },
            {
              "name": "messaging.system",
              "type": "STRING",
              "semconv": true
            }
          ]
        }
      ]
    },
    "otel.instrumentation.kafka.experimental-span-attributes=true": {
      "metrics": [],
      "spans": [
        {
          "span_kind": "CONSUMER",
          "attributes": [
            {
              "name": "kafka.record.queue_time_ms",
              "type": "LONG",
              "semconv": false
            },
            {
              "name": "messaging.client_id",
              "type": "STRING",
              "semconv": false
            },
            {
              "name": "messaging.destination.name",
              "type": "STRING",
              "semconv": true
            },
            {
              "name": "messaging.destination.partition.id",
              "type": "STRING",
              "semconv": true
            },
            {
              "name": "messaging.kafka.message.key",
              "type": "STRING",
              "semconv": true
            },
            {
              "name": "messaging.kafka.message.offset",
              "type": "LONG",
              "semconv": false
            },
            {
              "name": "messaging.message.body.size",
              "type": "LONG",
              "semconv": true
            },
            {
              "name": "messaging.operation",
              "type": "STRING",
              "semconv": false
            },
            {
              "name": "messaging.system",
              "type": "STRING",
              "semconv": true
            }
          ]
        }
      ]
    }
  }
}