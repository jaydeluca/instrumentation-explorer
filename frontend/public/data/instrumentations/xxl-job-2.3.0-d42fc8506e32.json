{
  "id": "xxl-job-2.3.0",
  "display_name": "XXL-Job",
  "library_group": "xxl",
  "description": "This instrumentation enables spans for XXL-Job task executions.",
  "library_link": "https://github.com/xuxueli/xxl-job",
  "source_path": "instrumentation/xxl-job/xxl-job-2.3.0",
  "scope": {
    "name": "io.opentelemetry.xxl-job-2.3.0"
  },
  "javaagent_target_versions": [
    "com.xuxueli:xxl-job-core:[2.3.0,)"
  ],
  "configurations": [
    {
      "name": "otel.instrumentation.xxl-job.experimental-span-attributes",
      "description": "Enables experimental span attributes `job.system`, `scheduling.xxl-job.glue.type`, and `scheduling.xxl-job.job.id`.\n",
      "type": "boolean",
      "default": false
    }
  ],
  "telemetry": {
    "default": {
      "metrics": [],
      "spans": [
        {
          "span_kind": "INTERNAL",
          "attributes": [
            {
              "name": "code.function",
              "type": "STRING",
              "semconv": true
            },
            {
              "name": "code.namespace",
              "type": "STRING",
              "semconv": true
            }
          ]
        }
      ]
    },
    "otel.instrumentation.xxl-job.experimental-span-attributes=true": {
      "metrics": [],
      "spans": [
        {
          "span_kind": "INTERNAL",
          "attributes": [
            {
              "name": "code.function",
              "type": "STRING",
              "semconv": true
            },
            {
              "name": "code.namespace",
              "type": "STRING",
              "semconv": true
            },
            {
              "name": "job.system",
              "type": "STRING",
              "semconv": false
            },
            {
              "name": "scheduling.xxl-job.glue.type",
              "type": "STRING",
              "semconv": false
            },
            {
              "name": "scheduling.xxl-job.job.id",
              "type": "LONG",
              "semconv": false
            }
          ]
        }
      ]
    }
  }
}