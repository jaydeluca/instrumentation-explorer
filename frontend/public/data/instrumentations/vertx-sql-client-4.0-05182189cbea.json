{
  "id": "vertx-sql-client-4.0",
  "display_name": "Vert.x SQL Client",
  "library_group": "vertx",
  "description": "This instrumentation enables database client spans and database client metrics for Vert.x SQL Client operations.\n",
  "library_link": "https://github.com/eclipse-vertx/vertx-sql-client",
  "source_path": "instrumentation/vertx/vertx-sql-client/vertx-sql-client-4.0",
  "semantic_conventions": [
    "DATABASE_CLIENT_SPANS",
    "DATABASE_CLIENT_METRICS"
  ],
  "scope": {
    "name": "io.opentelemetry.vertx-sql-client-4.0"
  },
  "javaagent_target_versions": [
    "io.vertx:vertx-sql-client:[4.0.0,5)"
  ],
  "configurations": [
    {
      "name": "otel.instrumentation.common.db-statement-sanitizer.enabled",
      "description": "Enables statement sanitization for database queries.",
      "type": "boolean",
      "default": true
    }
  ],
  "telemetry": {
    "default": {
      "metrics": [
        {
          "name": "db.client.operation.duration",
          "description": "Duration of database client operations.",
          "instrument": "histogram",
          "data_type": "HISTOGRAM",
          "unit": "s",
          "attributes": [
            {
              "name": "db.namespace",
              "type": "STRING",
              "semconv": true
            },
            {
              "name": "db.query.summary",
              "type": "STRING",
              "semconv": true
            },
            {
              "name": "server.address",
              "type": "STRING",
              "semconv": true
            },
            {
              "name": "server.port",
              "type": "LONG",
              "semconv": true
            }
          ]
        }
      ],
      "spans": [
        {
          "span_kind": "CLIENT",
          "attributes": [
            {
              "name": "db.namespace",
              "type": "STRING",
              "semconv": true
            },
            {
              "name": "db.query.summary",
              "type": "STRING",
              "semconv": true
            },
            {
              "name": "db.query.text",
              "type": "STRING",
              "semconv": true
            },
            {
              "name": "error.type",
              "type": "STRING",
              "semconv": true
            },
            {
              "name": "server.address",
              "type": "STRING",
              "semconv": true
            },
            {
              "name": "server.port",
              "type": "LONG",
              "semconv": true
            },
            {
              "name": "service.peer.name",
              "type": "STRING",
              "semconv": true
            }
          ]
        }
      ]
    }
  }
}