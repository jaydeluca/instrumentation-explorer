{
  "id": "vertx-kafka-client-3.6",
  "display_name": "Vert.x Kafka Client",
  "library_group": "vertx",
  "description": "This instrumentation enables messaging spans for Kafka consumers using the Vert.x Kafka Client library.\n",
  "library_link": "https://vertx.io/docs/vertx-kafka-client/java/",
  "source_path": "instrumentation/vertx/vertx-kafka-client-3.6",
  "semantic_conventions": [
    "MESSAGING_SPANS"
  ],
  "disabled_by_default": true,
  "scope": {
    "name": "io.opentelemetry.vertx-kafka-client-3.6"
  },
  "javaagent_target_versions": [
    "io.vertx:vertx-kafka-client:[3.5.1,)"
  ],
  "configurations": [
    {
      "name": "otel.instrumentation.kafka.producer-propagation.enabled",
      "description": "Enable context propagation for Kafka message producers.",
      "type": "boolean",
      "default": true
    },
    {
      "name": "otel.instrumentation.kafka.experimental-span-attributes",
      "description": "Enables the capture of the experimental consumer attribute `kafka.record.queue_time_ms`.",
      "type": "boolean",
      "default": false
    },
    {
      "name": "otel.instrumentation.messaging.experimental.capture-headers",
      "description": "A comma-separated list of header names to capture as span attributes.",
      "type": "list",
      "default": ""
    },
    {
      "name": "otel.instrumentation.messaging.experimental.receive-telemetry.enabled",
      "description": "Enables experimental receive telemetry, which will cause consumers to start a new trace, with only a span link connecting it to the producer trace.\n",
      "type": "boolean",
      "default": false
    }
  ],
  "telemetry": {
    "default": {
      "metrics": [],
      "spans": [
        {
          "span_kind": "CONSUMER",
          "attributes": [
            {
              "name": "messaging.batch.message_count",
              "type": "LONG",
              "semconv": true
            },
            {
              "name": "messaging.client_id",
              "type": "STRING",
              "semconv": false
            },
            {
              "name": "messaging.destination.name",
              "type": "STRING",
              "semconv": true
            },
            {
              "name": "messaging.destination.partition.id",
              "type": "STRING",
              "semconv": true
            },
            {
              "name": "messaging.kafka.message.key",
              "type": "STRING",
              "semconv": true
            },
            {
              "name": "messaging.kafka.message.offset",
              "type": "LONG",
              "semconv": false
            },
            {
              "name": "messaging.message.body.size",
              "type": "LONG",
              "semconv": true
            },
            {
              "name": "messaging.operation",
              "type": "STRING",
              "semconv": false
            },
            {
              "name": "messaging.system",
              "type": "STRING",
              "semconv": true
            }
          ]
        }
      ]
    },
    "otel.instrumentation.kafka.experimental-span-attributes=true": {
      "metrics": [],
      "spans": [
        {
          "span_kind": "CONSUMER",
          "attributes": [
            {
              "name": "kafka.record.queue_time_ms",
              "type": "LONG",
              "semconv": false
            },
            {
              "name": "messaging.batch.message_count",
              "type": "LONG",
              "semconv": true
            },
            {
              "name": "messaging.client_id",
              "type": "STRING",
              "semconv": false
            },
            {
              "name": "messaging.destination.name",
              "type": "STRING",
              "semconv": true
            },
            {
              "name": "messaging.destination.partition.id",
              "type": "STRING",
              "semconv": true
            },
            {
              "name": "messaging.kafka.message.key",
              "type": "STRING",
              "semconv": true
            },
            {
              "name": "messaging.kafka.message.offset",
              "type": "LONG",
              "semconv": false
            },
            {
              "name": "messaging.message.body.size",
              "type": "LONG",
              "semconv": true
            },
            {
              "name": "messaging.operation",
              "type": "STRING",
              "semconv": false
            },
            {
              "name": "messaging.system",
              "type": "STRING",
              "semconv": true
            }
          ]
        }
      ]
    }
  }
}